@{
    ViewData["Title"] = "Bem-vindo - ConnectaMente";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center align-items-center" style="min-height: 65vh;">
        <div class="col-md-7 text-center">
            <div class="mb-4">
                <i class="bi bi-shield-lock-fill text-primary" style="font-size: 4.5rem;"></i>
            </div>
            <h1 class="fw-bold display-4">ConnectaMente</h1>
            <p class="lead text-muted mb-5">
                Plataforma de gestão para Clínica-Escola de Psicologia.<br>
                Segurança, sigilo e organização para o seu atendimento acadêmico.
            </p>
            
            <div class="card border-0 shadow p-4 bg-light">
                <h5 class="fw-bold mb-3">Acesso Restrito</h5>
                <p class="text-muted mb-4">É necessário estar autenticado para visualizar o dashboard e os prontuários.</p>
                <div class="d-grid gap-2">
                    <a href="/Identity/Account/Login" class="btn btn-primary btn-lg shadow-sm">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Entrar no Sistema
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>