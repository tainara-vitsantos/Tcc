@model ClinicaEscolaBase.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Corporativo";
    Layout = "_LayoutAdmin";
    bool isProfessor = Model?.IsProfessor ?? false;
}

<div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-3 border-bottom border-light gap-3">
    <div>
        <h1 class="h3 fw-bold text-dark mb-1">Painel Geral</h1>
        <div class="text-muted small">Indicadores operacionais consolidados e integrados à clínica-escola.</div>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-light border bg-white rounded-3 shadow-sm btn-sm px-3 text-secondary py-2 fw-medium transition-smooth" asp-controller="Relatorio" asp-action="Index">
            <i class="bi bi-file-earmark-text me-1 text-muted"></i> Exportar Relatório
        </a>
    </div>
</div>

<section class="mb-4">
    <div class="row g-4">
        <div class="col-12 col-md-4">
            <div class="card-saas p-4 bg-white d-flex align-items-center justify-content-between position-relative overflow-hidden border rounded-4 transition-smooth">
                <div>
                    <span class="text-muted small fw-semibold text-uppercase tracking-wider d-block mb-1" style="font-size: 0.75rem;">Pacientes Ativos</span>
                    <h2 class="fw-extrabold text-dark m-0 display-6 font-sans">
                        @(Model?.ProfessorData?.TotalPacientes ?? Model?.AlunoData?.MeusPacientes ?? 0)
                    </h2>
                    <small class="text-muted mt-1 d-block" style="font-size: 0.8rem;">Carteira clínica sob acompanhamento</small>
                </div>
                <div class="p-3 bg-primary bg-opacity-10 text-primary rounded-4">
                    <i class="bi bi-people fs-4"></i>
                </div>
                <div class="position-absolute bottom-0 start-0 end-0 bg-primary" style="height: 3.5px; opacity: 0.85;"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card-saas p-4 bg-white d-flex align-items-center justify-content-between position-relative overflow-hidden border rounded-4 transition-smooth">
                <div>
                    <span class="text-muted small fw-semibold text-uppercase tracking-wider d-block mb-1" style="font-size: 0.75rem;">Atendimentos Hoje</span>
                    <h2 class="fw-extrabold text-dark m-0 display-6 font-sans">
                        @(Model?.ProfessorData?.AtendimentosHoje ?? Model?.AlunoData?.MeusAtendimentosHoje ?? 0)
                    </h2>
                    <small class="text-muted mt-1 d-block" style="font-size: 0.8rem;">Sessões agendadas na data atual</small>
                </div>
                <div class="p-3 bg-info bg-opacity-10 text-info rounded-4">
                    <i class="bi bi-calendar-check fs-4"></i>
                </div>
                <div class="position-absolute bottom-0 start-0 end-0 bg-info" style="height: 3.5px; opacity: 0.85;"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card-saas p-4 bg-white d-flex align-items-center justify-content-between position-relative overflow-hidden border rounded-4 transition-smooth">
                <div>
                    <span class="text-muted small fw-semibold text-uppercase tracking-wider d-block mb-1" style="font-size: 0.75rem;">Prontuários Ativos</span>
                    <h2 class="fw-extrabold text-dark m-0 display-6 font-sans">
                        @(Model?.ProfessorData?.TotalProntuariosAtivos ?? 0)
                    </h2>
                    <small class="text-muted mt-1 d-block" style="font-size: 0.8rem;">Registros digitais em evolução</small>
                </div>
                <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-4">
                    <i class="bi bi-file-earmark-medical fs-4"></i>
                </div>
                <div class="position-absolute bottom-0 start-0 end-0 bg-warning" style="height: 3.5px; opacity: 0.85;"></div>
            </div>
        </div>
    </div>
</section>

<div class="row g-4 mb-4">
    <div class="col-12 col-lg-8">
        
        <div class="card-saas border overflow-hidden mb-4 rounded-4 bg-white">
            <div class="p-4 border-bottom border-light d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-0 fw-bold text-dark">Próximos Atendimentos</h5>
                    <small class="text-muted">Lista limitada aos próximos 10 registros agendados</small>
                </div>
                <span class="badge bg-light text-muted border px-2.5 py-1.5 rounded-pill font-monospace" style="font-size: 0.75rem;">Fila Real-time</span>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Paciente</th>
                            <th class="py-3">Data / Horário</th>
                            @if (isProfessor) { <th class="py-3">Aluno Vinculado</th> }
                            <th class="text-end pe-4 py-3">Ação</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ var atendimentos = isProfessor ? Model?.ProfessorData?.ProximosAtendimentos : Model?.AlunoData?.MeusProximosAtendimentos; }
                        @if (atendimentos != null && atendimentos.Any())
                        {
                            foreach(var a in atendimentos)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center gap-2.5">
                                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-semibold text-uppercase" style="width: 34px; height: 34px; font-size: 0.75rem; letter-spacing: -0.5px;">
                                                @(a.Paciente?.NomeCompleto != null && a.Paciente.NomeCompleto.Length >= 2 ? a.Paciente.NomeCompleto.Substring(0, 2) : "PA")
                                            </div>
                                            <span class="fw-semibold text-dark" style="font-size: 0.9rem;">@a.Paciente?.NomeCompleto</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-secondary border font-monospace px-2.5 py-1.5" style="font-size: 0.8rem;">
                                            <i class="bi bi-calendar-event me-1.5 text-muted"></i>@a.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                    @if (isProfessor) 
                                    { 
                                        <td><span class="text-secondary small fw-medium">@a.Aluno?.NomeCompleto</span></td> 
                                    }
                                    <td class="text-end pe-4">
                                        <a class="btn btn-sm btn-white border rounded-3 px-3 fw-medium text-dark shadow-2-strong transition-smooth" asp-controller="Atendimento" asp-action="Details" asp-route-id="@a.Id">
                                            <i class="bi bi-folder2-open me-1 text-primary"></i> Abrir Prontuário
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(isProfessor ? 4 : 3)" class="text-center text-muted py-5">
                                    <div class="py-2">
                                        <i class="bi bi-calendar-x fs-2 opacity-40 d-block mb-2 text-secondary"></i>
                                        <span class="small fw-medium">Nenhum atendimento clínico agendado.</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-saas p-4 bg-white border rounded-4">
            <h5 class="fw-bold text-dark mb-4"><i class="bi bi-journal-text text-primary me-2"></i>Histórico Operacional Recente</h5>
            <div class="position-relative ms-2">
                <div class="position-absolute h-100 start-0 top-0 border-start" style="width: 2px; border-color: #E2E8F0 !important; left: 11px;"></div>
                
                <div class="d-flex mb-4 position-relative gap-3 align-items-start ps-4">
                    <div class="bg-white border border-2 rounded-circle d-flex align-items-center justify-content-center text-primary position-absolute start-0" style="width: 24px; height: 24px; left: 0px; z-index: 2; border-color: var(--primary) !important;">
                        <span class="p-1 bg-teal rounded-circle" style="background-color: var(--primary); width: 8px; height: 8px;"></span>
                    </div>
                    <div class="w-100 card border-0 p-3 rounded-3 bg-light bg-opacity-40 shadow-sm">
                        <div class="d-flex flex-column flex-sm-row justify-content-between mb-1.5">
                            <span class="fw-bold text-dark small">Assinatura de Registro de Prontuário</span>
                            <small class="text-muted font-monospace small">Hoje — 11:23</small>
                        </div>
                        <p class="mb-0 text-muted small">Evolução clínica consolidada e assinada para o paciente <strong class="text-dark">João Silva</strong>.</p>
                    </div>
                </div>

                <div class="d-flex mb-2 position-relative gap-3 align-items-start ps-4">
                    <div class="bg-white border border-2 rounded-circle d-flex align-items-center justify-content-center text-success position-absolute start-0" style="width: 24px; height: 24px; left: 0px; z-index: 2; border-color: #10B981 !important;">
                        <span class="p-1 bg-success rounded-circle" style="width: 8px; height: 8px;"></span>
                    </div>
                    <div class="w-100 card border-0 p-3 rounded-3 bg-light bg-opacity-40 shadow-sm">
                        <div class="d-flex flex-column flex-sm-row justify-content-between mb-1.5">
                            <span class="fw-bold text-dark small">Atendimento Técnico Finalizado</span>
                            <small class="text-muted font-monospace small">Ontem — 16:10</small>
                        </div>
                        <p class="mb-0 text-muted small">Sessão psicoterapêutica concluída pela acadêmica <strong class="text-dark">Maria Medeiros</strong>.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-4">
        <div class="card-saas p-4 bg-white border rounded-4 mb-4">
            <h5 class="fw-bold text-dark mb-1">Composição Operacional</h5>
            <p class="text-muted small mb-3">Distribuição volumétrica das entidades de dados</p>
            <div class="position-relative d-flex align-items-center justify-content-center" style="height: 220px;">
                <canvas id="kpiChart"></canvas>
            </div>
        </div>

        <div class="card-saas p-4 bg-white border rounded-4">
            <h5 class="fw-bold text-dark mb-3">Logs Diretos do Sistema</h5>
            <div class="d-flex flex-column gap-3">
                <div class="p-2.5 border-bottom border-light bg-light bg-opacity-20 rounded-3">
                    <div class="d-flex justify-content-between align-items-center mb-1.5">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary small px-2 py-1">Auditoria</span>
                        <small class="text-muted font-monospace" style="font-size: 0.72rem;">@DateTime.Now.ToString("dd/MM HH:mm")</small>
                    </div>
                    <small class="text-dark d-block fw-bold mb-0.5">Nova auditoria realizada</small>
                    <small class="text-muted small">Módulo validado com sucesso pelo Supervisor da sessão.</small>
                </div>
                <div class="p-2.5 bg-light bg-opacity-20 rounded-3">
                    <div class="d-flex justify-content-between align-items-center mb-1.5">
                        <span class="badge bg-primary bg-opacity-10 text-primary small px-2 py-1">Cadastro</span>
                        <small class="text-muted font-monospace" style="font-size: 0.72rem;">Ontem</small>
                    </div>
                    <small class="text-dark d-block fw-bold mb-0.5">Paciente integrado</small>
                    <small class="text-muted small">Fila de triagem atualizada via formulário acadêmico.</small>
                </div>
            </div>
        </div>
    </div>
</div>

@if (isProfessor && Model?.ProfessorData?.AuditoriasRecentes != null)
{
    <div class="card-saas border overflow-hidden mb-4 rounded-4 bg-white">
        <div class="p-4 border-bottom border-light d-flex align-items-center justify-content-between">
            <div>
                <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-shield-check text-secondary me-2"></i>Histórico Completo de Auditoria</h5>
                <small class="text-muted">Logs de segurança e acessos indexados no ecossistema de saúde</small>
            </div>
            <span class="badge bg-secondary bg-opacity-10 text-secondary fw-semibold px-2.5 py-1.5">Security Engine</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Usuário</th>
                        <th class="py-3">Ação Executada</th>
                        <th class="py-3">Paciente Afetado</th>
                        <th class="py-3 pe-4">Data e Hora</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.ProfessorData.AuditoriasRecentes.Any())
                    {
                        foreach (var log in Model.ProfessorData.AuditoriasRecentes)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark" style="font-size: 0.9rem;">@log.Usuario?.NomeCompleto</td>
                                <td>
                                    <span class="badge bg-light text-secondary border font-monospace px-2.5 py-1.5" style="font-size: 0.78rem;">@log</span>
                                </td>
                                <td class="text-secondary small fw-medium">@log.Paciente?.NomeCompleto</td>
                                <td class="text-muted pe-4 small font-monospace">
                                    <i class="bi bi-calendar3 me-1.5"></i>@log.DataHora.ToString("dd/MM/yyyy HH:mm:ss")
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-5">
                                <div class="py-2">
                                    <i class="bi bi-info-circle fs-2 text-muted opacity-40 d-block mb-2"></i>
                                    <span class="small fw-medium">Nenhum evento de segurança catalogado no servidor.</span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script>
        (function(){
            const ctx = document.getElementById('kpiChart')?.getContext('2d');
            if(!ctx) return;
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Atendimentos', 'Prontuários', 'Pacientes'],
                    datasets: [{ 
                        data: [
                            @(Model?.ProfessorData?.AtendimentosHoje ?? Model?.AlunoData?.MeusAtendimentosHoje ?? 0), 
                            @(Model?.ProfessorData?.TotalProntuariosAtivos ?? 0), 
                            @(Model?.ProfessorData?.TotalPacientes ?? Model?.AlunoData?.MeusPacientes ?? 0)
                        ], 
                        backgroundColor: ['#0D9488', '#06B6D4', '#F59E0B'],
                        borderWidth: 4,
                        borderColor: '#ffffff',
                        hoverOffset: 6
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    animation: {
                        duration: 1200,
                        easing: 'easeOutQuart'
                    },
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: { family: 'Inter', size: 11, weight: '500' },
                                boxWidth: 10,
                                padding: 16,
                                usePointStyle: true
                            }
                        },
                        tooltip: {
                            backgroundColor: '#0F172A',
                            titleFont: { family: 'Inter', size: 12 },
                            bodyFont: { family: 'Inter', size: 12 },
                            padding: 10,
                            cornerRadius: 8
                        }
                    },
                    cutout: '76%' /* Garante a proporção vazada exata e elegante igual ao print */
                }
            });
        })();
    </script>
}