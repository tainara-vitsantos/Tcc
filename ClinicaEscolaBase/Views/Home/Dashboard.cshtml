@model ClinicaEscolaBase.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard - ConnectaMente";
    Layout = "_LayoutAdmin";
    
    bool isProfessor = Model.IsProfessor;
}

<div class="container-fluid px-4 mt-4">
    <h2 class="fw-bold mb-4">Dashboard @(isProfessor ? "do Supervisor" : "do Aluno")</h2>

    @* --- BLOCO DE CARDS INDICADORES --- *@
    <div class="row g-3 mb-4">
        @if (isProfessor && Model.ProfessorData != null)
        {
            <div class="col-md-3">
                <div class="card bg-primary text-white border-0 shadow-sm p-3">
                    <small>Total de Pacientes</small>
                    <h3 class="fw-bold m-0">@Model.ProfessorData.TotalPacientes</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white border-0 shadow-sm p-3">
                    <small>Atendimentos Hoje</small>
                    <h3 class="fw-bold m-0">@Model.ProfessorData.AtendimentosHoje</h3>
                </div>
            </div>
        }
        else if (!isProfessor && Model.AlunoData != null)
        {
            <div class="col-md-3">
                <div class="card bg-info text-white border-0 shadow-sm p-3">
                    <small>Meus Pacientes</small>
                    <h3 class="fw-bold m-0">@Model.AlunoData.MeusPacientes</h3>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark border-0 shadow-sm p-3">
                    <small>Minha Agenda Hoje</small>
                    <h3 class="fw-bold m-0">@Model.AlunoData.MeusAtendimentosHoje</h3>
                </div>
            </div>
        }
    </div>

    @* --- TABELA DE PRÓXIMOS ATENDIMENTOS --- *@
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-event me-2"></i>Próximos Atendimentos</h5>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Paciente</th>
                        <th>Data/Hora</th>
                        @if (isProfessor) { <th>Aluno Responsável</th> }
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var atendimentos = isProfessor 
                            ? Model.ProfessorData?.ProximosAtendimentos 
                            : Model.AlunoData?.MeusProximosAtendimentos;
                    }

                    @if (atendimentos != null && atendimentos.Any())
                    {
                        foreach (var item in atendimentos)
                        {
                            <tr>
                                <td><strong>@item.Paciente?.NomeCompleto</strong></td>
                                <td>@item.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")</td>
                                @if (isProfessor) { <td>@item.Aluno?.NomeCompleto</td> }
                                <td class="text-end">
                                    <a asp-controller="Atendimento" asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Abrir</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        @* Feedback visual caso a lista esteja vazia *@
                        <tr>
                            <td colspan="@(isProfessor ? 4 : 3)" class="text-center text-muted py-4">
                                <i class="bi bi-calendar-x fs-4 d-block mb-2"></i>
                                Nenhum atendimento agendado encontrado.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* --- SEÇÃO EXCLUSIVA DO SUPERVISOR: AUDITORIA --- *@
    @if (isProfessor && Model.ProfessorData?.AuditoriasRecentes != null)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-bold text-secondary"><i class="bi bi-shield-check me-2"></i>Histórico Recente de Auditoria</h5>
            </div>
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Usuário</th>
                            <th>Ação Executada</th>
                            <th>Paciente Afetado</th>
                            <th>Data e Hora</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ProfessorData.AuditoriasRecentes.Any())
                        {
                            foreach (var log in Model.ProfessorData.AuditoriasRecentes)
                            {
                                <tr>
                                    <td>@log.Usuario?.NomeCompleto</td>
                                    <td><span class="badge bg-light text-dark border">@log</span></td>
                                    <td>@log.Paciente?.NomeCompleto</td>
                                    <td>@log.DataHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    Nenhuma atividade registrada no sistema.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>