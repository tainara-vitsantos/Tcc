@{
    ViewData["Title"] = "Usuários";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="fas fa-users text-primary me-2"></i>
                Gestão de Usuários
            </h2>
            <p class="text-muted mb-0">
                Gerencie acessos, perfis e permissões dos usuários do sistema.
            </p>
        </div>

        <button class="btn btn-primary">
            <i class="fas fa-user-plus me-2"></i>
            Novo Usuário
        </button>
    </div>

    <!-- Indicadores -->

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <small class="text-muted">Total de Usuários</small>
                    <h3 class="fw-bold">54</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <small class="text-muted">Professores</small>
                    <h3 class="fw-bold text-success">12</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <small class="text-muted">Alunos</small>
                    <h3 class="fw-bold text-primary">34</h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <small class="text-muted">Administradores</small>
                    <h3 class="fw-bold text-danger">8</h3>
                </div>
            </div>
        </div>

    </div>

    <!-- Filtros -->

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <h5 class="fw-bold mb-3">
                Filtros
            </h5>

            <div class="row">

                <div class="col-md-4">
                    <label class="form-label">Pesquisar</label>
                    <input type="text"
                           class="form-control"
                           placeholder="Nome, e-mail ou matrícula">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Perfil</label>
                    <select class="form-select">
                        <option>Todos</option>
                        <option>Administrador</option>
                        <option>Professor</option>
                        <option>Aluno</option>
                        <option>Recepcionista</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <select class="form-select">
                        <option>Todos</option>
                        <option>Ativo</option>
                        <option>Inativo</option>
                    </select>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-outline-primary w-100">
                        Filtrar
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- Tabela -->

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white">
            <h5 class="fw-bold mb-0">
                Usuários Cadastrados
            </h5>
        </div>

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>E-mail</th>
                        <th>Perfil</th>
                        <th>Status</th>
                        <th>Último Acesso</th>
                        <th width="180">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>Maria Silva</td>
                        <td>maria@clinica.com</td>
                        <td>
                            <span class="badge bg-danger">
                                Administrador
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-success">
                                Ativo
                            </span>
                        </td>
                        <td>10/06/2026 08:30</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                Editar
                            </button>

                            <button class="btn btn-sm btn-outline-danger">
                                Excluir
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>João Santos</td>
                        <td>joao@clinica.com</td>
                        <td>
                            <span class="badge bg-success">
                                Professor
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-success">
                                Ativo
                            </span>
                        </td>
                        <td>09/06/2026 17:15</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                Editar
                            </button>

                            <button class="btn btn-sm btn-outline-danger">
                                Excluir
                            </button>
                        </td>
                    </tr>

                    <tr>
                        <td>Ana Oliveira</td>
                        <td>ana@clinica.com</td>
                        <td>
                            <span class="badge bg-primary">
                                Aluno
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-secondary">
                                Inativo
                            </span>
                        </td>
                        <td>01/06/2026 13:42</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary">
                                Editar
                            </button>

                            <button class="btn btn-sm btn-outline-danger">
                                Excluir
                            </button>
                        </td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

</div>