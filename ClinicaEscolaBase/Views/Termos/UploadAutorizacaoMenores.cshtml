@model ClinicaEscolaBase.ViewModels.TermoUploadViewModel
@{
    ViewData["Title"] = "Upload de Autorização de Menores";
}

<div class="container-fluid">
    <h2>@ViewData["Title"] - @Model.PacienteNome</h2>

    <form asp-action="UploadAutorizacaoMenores" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PacienteId" />
        <input type="hidden" asp-for="ProntuarioId" />

        <div class="card mb-3">
            <div class="card-header fw-bold">Arquivo de Autorização</div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="Arquivo" class="form-label"></label>
                    <input asp-for="Arquivo" class="form-control" type="file" accept="application/pdf" />
                    <span asp-validation-for="Arquivo" class="text-danger"></span>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Enviar Autorização</button>
        <a asp-action="UploadAutorizacaoMenores" asp-route-pacienteId="@Model.PacienteId" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
