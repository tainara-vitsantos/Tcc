@model ClinicaEscolaBase.Models.ProntuarioModel

@{
    ViewData["Title"] = "Abrir Prontuário";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <h2 class="fw-bold text-success"><i class="bi bi-folder-plus"></i> Abrir Novo Prontuário</h2>
    <p class="text-muted">Iniciando registro clínico para: <strong>@ViewBag.PacienteNome</strong></p>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                @* Vinculo essencial com o paciente *@
                <input type="hidden" asp-for="PacienteId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NumeroProntuario" class="form-label fw-bold">Número do Prontuário</label>
                        <input asp-for="NumeroProntuario" class="form-control" placeholder="Ex: 2026-001" />
                        <span asp-validation-for="NumeroProntuario" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="DataPrimeiraConsulta" class="form-label fw-bold">Data da Primeira Consulta</label>
                        <input asp-for="DataPrimeiraConsulta" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="DataPrimeiraConsulta" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ObservacoesGerais" class="form-label fw-bold">Observações Iniciais</label>
                    <textarea asp-for="ObservacoesGerais" class="form-control" rows="4" placeholder="Alguma observação relevante sobre a abertura deste prontuário..."></textarea>
                    <span asp-validation-for="ObservacoesGerais" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success px-4">Gravar Prontuário</button>
                    <a asp-controller="Paciente" asp-action="Details" asp-route-id="@Model.PacienteId" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>