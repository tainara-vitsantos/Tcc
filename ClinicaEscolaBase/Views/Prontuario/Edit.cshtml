@model ClinicaEscolaBase.Models.ProntuarioModel
@{
    ViewData["Title"] = "Editar Prontuário Clínico";
    Layout = "_LayoutAdmin";
}
<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark fw-bold">Editar Prontuário</div>
        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="PacienteId" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NumeroProntuario" class="form-label fw-bold"></label>
                        <input asp-for="NumeroProntuario" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="SituacaoProntuario" class="form-label fw-bold"></label>
                        <select asp-for="SituacaoProntuario" class="form-select" asp-items="Html.GetEnumSelectList<ClinicaEscolaBase.Enums.SituacaoProntuarioEnum>()"></select>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="ObservacoesGerais" class="form-label fw-bold">Observações Clínicas Iniciais</label>
                    <textarea asp-for="ObservacoesGerais" class="form-control" rows="4"></textarea>
                </div>

                <button type="submit" class="btn btn-warning px-4">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
            </form>
        </div>
    </div>
</div>