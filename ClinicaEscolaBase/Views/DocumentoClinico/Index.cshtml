@model IEnumerable<ClinicaEscolaBase.Models.DocumentoClinico>
@using ClinicaEscolaBase.Enums

@{
    ViewData["Title"] = "Documentos Clínicos";
        Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary"><i class="bi bi-journal-medical me-2"></i>Documentos Clínicos</h1>
            <p class="text-muted mb-0">Lista de documentos que você tem permissão para visualizar.</p>
        </div>
        <a asp-controller="Paciente" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left-circle me-1"></i>Voltar aos pacientes
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">Nenhum documento encontrado.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tipo</th>
                        <th>Paciente</th>
                        <th>Prontuário</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var documento in Model)
                    {
                        <tr>
                            <td>@documento.TipoDocumento</td>
                            <td>@documento.Paciente?.NomeCompleto</td>
                            <td>@documento.Prontuario?.NumeroProntuario</td>
                            <td>@documento.DataDocumento.ToString("dd/MM/yyyy")</td>
                            <td>@documento.StatusDocumento</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@documento.Id" class="btn btn-sm btn-outline-primary">
                                    Detalhes
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
