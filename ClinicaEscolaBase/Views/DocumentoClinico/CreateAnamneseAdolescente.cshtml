@model ClinicaEscolaBase.ViewModels.AnamneseAdolescenteViewModel
@{
    ViewData["Title"] = "Anamnese Adolescente";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid">
    <h2>@ViewData["Title"] - @Model.PacienteNome</h2>

    <form method="post" asp-action="CreateAnamneseAdolescente">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PacienteId" />
        <input type="hidden" asp-for="ProntuarioId" />

        <!-- Seção 1: Dados Escolares e Pais -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>Dados Escolares e Pais</h5>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label asp-for="Escola"></label>
                    <input asp-for="Escola" class="form-control" />
                    <span asp-validation-for="Escola" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <h6>Pai</h6>
                        <div class="form-group">
                            <label asp-for="PaiNome"></label>
                            <input asp-for="PaiNome" class="form-control" />
                            <span asp-validation-for="PaiNome" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="PaiIdade"></label>
                            <input asp-for="PaiIdade" class="form-control" type="number" />
                            <span asp-validation-for="PaiIdade" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="PaiInstrucao"></label>
                            <input asp-for="PaiInstrucao" class="form-control" />
                            <span asp-validation-for="PaiInstrucao" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="PaiProfissao"></label>
                            <input asp-for="PaiProfissao" class="form-control" />
                            <span asp-validation-for="PaiProfissao" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Mãe</h6>
                        <div class="form-group">
                            <label asp-for="MaeNome"></label>
                            <input asp-for="MaeNome" class="form-control" />
                            <span asp-validation-for="MaeNome" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="MaeIdade"></label>
                            <input asp-for="MaeIdade" class="form-control" type="number" />
                            <span asp-validation-for="MaeIdade" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="MaeInstrucao"></label>
                            <input asp-for="MaeInstrucao" class="form-control" />
                            <span asp-validation-for="MaeInstrucao" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="MaeProfissao"></label>
                            <input asp-for="MaeProfissao" class="form-control" />
                            <span asp-validation-for="MaeProfissao" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="CondicaoConjugalPais"></label>
                    <input asp-for="CondicaoConjugalPais" class="form-control" />
                    <span asp-validation-for="CondicaoConjugalPais" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Seção 2: Queixa Principal -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>Queixa Principal</h5>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label asp-for="QueixaPrincipal"></label>
                    <textarea asp-for="QueixaPrincipal" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="QueixaPrincipal" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DesdeQuando"></label>
                    <input asp-for="DesdeQuando" class="form-control" />
                    <span asp-validation-for="DesdeQuando" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AtitudeMaeFrenteQueixa"></label>
                    <textarea asp-for="AtitudeMaeFrenteQueixa" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="AtitudeMaeFrenteQueixa" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AtitudePaiFrenteQueixa"></label>
                    <textarea asp-for="AtitudePaiFrenteQueixa" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="AtitudePaiFrenteQueixa" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="AtitudeOutrosFamiliares"></label>
                    <textarea asp-for="AtitudeOutrosFamiliares" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="AtitudeOutrosFamiliares" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Seção 3: História Pessoal -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>História Pessoal</h5>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label asp-for="FoiDesejado"></label>
                    <input asp-for="FoiDesejado" class="form-control" />
                    <span asp-validation-for="FoiDesejado" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Linguagem"></label>
                    <textarea asp-for="Linguagem" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Linguagem" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DesenvolvimentoPsicomotor"></label>
                    <textarea asp-for="DesenvolvimentoPsicomotor" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="DesenvolvimentoPsicomotor" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Sono"></label>
                            <input asp-for="Sono" class="form-control" />
                            <span asp-validation-for="Sono" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Alimentacao"></label>
                            <input asp-for="Alimentacao" class="form-control" />
                            <span asp-validation-for="Alimentacao" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="Tiques"></label>
                            <input asp-for="Tiques" class="form-control" />
                            <span asp-validation-for="Tiques" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="DificuldadeEscolar"></label>
                    <textarea asp-for="DificuldadeEscolar" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="DificuldadeEscolar" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Seção 4: Histórico Familiar -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>Histórico Familiar</h5>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label asp-for="FamiliarNervoso"></label>
                    <input asp-for="FamiliarNervoso" class="form-control" />
                    <span asp-validation-for="FamiliarNervoso" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="DescricaoFamiliarNervoso"></label>
                    <textarea asp-for="DescricaoFamiliarNervoso" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="DescricaoFamiliarNervoso" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="FamiliarProblemaMental"></label>
                    <input asp-for="FamiliarProblemaMental" class="form-control" />
                    <span asp-validation-for="FamiliarProblemaMental" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ViciosFamilia"></label>
                    <input asp-for="ViciosFamilia" class="form-control" />
                    <span asp-validation-for="ViciosFamilia" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Seção 5: Atividades e Companheiras -->
        <div class="card mb-3">
            <div class="card-header">
                <h5>Atividades e Companheiras</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="LocalEstudo"></label>
                            <input asp-for="LocalEstudo" class="form-control" />
                            <span asp-validation-for="LocalEstudo" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="TiposDiversao"></label>
                            <input asp-for="TiposDiversao" class="form-control" />
                            <span asp-validation-for="TiposDiversao" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="FamiliaFazVisitas"></label>
                            <input asp-for="FamiliaFazVisitas" class="form-control" />
                            <span asp-validation-for="FamiliaFazVisitas" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="FamiliaRecebeVisitas"></label>
                            <input asp-for="FamiliaRecebeVisitas" class="form-control" />
                            <span asp-validation-for="FamiliaRecebeVisitas" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="Companheiros"></label>
                    <textarea asp-for="Companheiros" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Companheiros" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="QuemEscolheCompanheiros"></label>
                    <input asp-for="QuemEscolheCompanheiros" class="form-control" />
                    <span asp-validation-for="QuemEscolheCompanheiros" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Religiao"></label>
                    <input asp-for="Religiao" class="form-control" />
                    <span asp-validation-for="Religiao" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Salvar Anamnese</button>
            <a asp-action="Details" asp-controller="Paciente" asp-route-id="@Model.PacienteId" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>