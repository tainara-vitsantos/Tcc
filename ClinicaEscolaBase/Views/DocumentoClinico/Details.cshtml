@model ClinicaEscolaBase.Models.DocumentoClinico

@{
    ViewData["Title"] = "Detalhes do Documento";
        Layout = "_LayoutAdmin";
    var canWrite = ViewBag.CanWrite as bool? ?? false;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary"><i class="bi bi-journal-text me-2"></i>Documento: @Model.TipoDocumento</h1>
            <p class="text-muted mb-0">Paciente: <strong>@Model.Paciente?.NomeCompleto</strong></p>
        </div>
        <div>
            <a asp-controller="DocumentoClinico" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left-circle me-1"></i>Voltar à lista
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">Informações do Documento</div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted">Paciente</dt>
                        <dd class="col-sm-8">@Model.Paciente?.NomeCompleto</dd>

                        <dt class="col-sm-4 text-muted">Prontuário</dt>
                        <dd class="col-sm-8">@Model.Prontuario?.NumeroProntuario</dd>

                        <dt class="col-sm-4 text-muted">Tipo</dt>
                        <dd class="col-sm-8">@Model.TipoDocumento</dd>

                        <dt class="col-sm-4 text-muted">Status</dt>
                        <dd class="col-sm-8">@Model.StatusDocumento</dd>

                        <dt class="col-sm-4 text-muted">Data de Criação</dt>
                        <dd class="col-sm-8">@Model.DataDocumento.ToString("dd/MM/yyyy HH:mm")</dd>

                        <dt class="col-sm-4 text-muted">Usuário criador</dt>
                        <dd class="col-sm-8">@Model.CriadoPorUsuario?.NomeCompleto</dd>

                        <dt class="col-sm-4 text-muted">Observações</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrWhiteSpace(Model.Observacoes))
                            {
                                <pre class="p-3 bg-light border rounded" style="white-space: pre-wrap;">@Model.Observacoes</pre>
                            }
                            else
                            {
                                <span class="text-muted">Sem observações registradas.</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white fw-bold">Anexos</div>
                <div class="card-body">
                    @if (Model.Anexos != null && Model.Anexos.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var anexo in Model.Anexos.OrderByDescending(a => a.DataUpload))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@anexo.NomeOriginal</strong><br />
                                        <small class="text-muted">@anexo.DataUpload.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                    <div class="btn-group" role="group">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-primary download-anexo"
                                                data-download-url="@Url.Action("Download", "Anexo", new { id = anexo.Id })"
                                                data-file-name="@anexo.NomeOriginal">
                                            <i class="bi bi-download"></i>
                                        </button>
                                        @if (canWrite)
                                        {
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger delete-anexo"
                                                    data-delete-url="@Url.Action("Delete", "Anexo")"
                                                    data-anexo-id="@anexo.Id">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            Nenhum anexo enviado para este documento.
                        </div>
                    }
                </div>
            </div>

            @if (canWrite)
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white fw-bold">Enviar anexo</div>
                    <div class="card-body">
                        <form id="uploadForm" asp-controller="Anexo" asp-action="Upload" method="post" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="documentoId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label">Arquivo PDF</label>
                                <input type="file" name="arquivo" class="form-control" accept=".pdf" required />
                            </div>
                            <button type="submit" class="btn btn-primary">Enviar anexo</button>
                        </form>
                        <div id="uploadMessage" class="mt-3"></div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light fw-bold">Ações</div>
                <div class="card-body d-grid gap-2">
                    <a asp-controller="Paciente" asp-action="Details" asp-route-id="@Model.PacienteId" class="btn btn-outline-secondary">
                        <i class="bi bi-person-badge me-1"></i>Ficha do paciente
                    </a>
                    <a asp-controller="Prontuario" asp-action="Details" asp-route-id="@Model.ProntuarioId" class="btn btn-outline-secondary">
                        <i class="bi bi-file-earmark-medical me-1"></i>Ver prontuário
                    </a>
                    <a asp-controller="DocumentoClinico" asp-action="Index" class="btn btn-outline-primary">
                        <i class="bi bi-list-ul me-1"></i>Voltar à lista de documentos
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const uploadForm = document.getElementById('uploadForm');
            const uploadMessage = document.getElementById('uploadMessage');

            function getAntiForgeryToken() {
                return uploadForm?.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
            }

            async function readResponsePayload(response) {
                const contentType = response.headers.get('content-type') || '';

                if (contentType.includes('application/json')) {
                    return await response.json();
                }

                const text = await response.text();
                try {
                    return JSON.parse(text);
                } catch {
                    return { message: text };
                }
            }

            function getFilenameFromContentDisposition(contentDisposition, fallbackName) {
                if (!contentDisposition) {
                    return fallbackName;
                }

                const utf8Match = /filename\*=UTF-8''([^;]+)/i.exec(contentDisposition);
                if (utf8Match && utf8Match[1]) {
                    return decodeURIComponent(utf8Match[1]);
                }

                const asciiMatch = /filename="?([^";]+)"?/i.exec(contentDisposition);
                if (asciiMatch && asciiMatch[1]) {
                    return asciiMatch[1];
                }

                return fallbackName;
            }

            async function downloadFile(url, fallbackName) {
                const response = await fetch(url, {
                    method: 'GET',
                    credentials: 'same-origin'
                });

                if (!response.ok) {
                    const result = await readResponsePayload(response);
                    throw new Error(result.message || 'Não foi possível baixar o anexo.');
                }

                const blob = await response.blob();
                const fileName = getFilenameFromContentDisposition(
                    response.headers.get('content-disposition'),
                    fallbackName
                );

                const objectUrl = window.URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = objectUrl;
                link.download = fileName;
                document.body.appendChild(link);
                link.click();
                link.remove();
                window.URL.revokeObjectURL(objectUrl);
            }

            async function postFormData(url, formData) {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin'
                });

                const result = await readResponsePayload(response);
                return { response, result };
            }

            if (uploadForm) {
                uploadForm.addEventListener('submit', async function (event) {
                    event.preventDefault();
                    const formData = new FormData(uploadForm);
                    const { response, result } = await postFormData(uploadForm.action, formData);
                    const messageClass = response.ok && result.success ? 'alert alert-success' : 'alert alert-danger';
                    uploadMessage.innerHTML = `<div class="${messageClass}">${result.message || 'Não foi possível enviar o anexo.'}</div>`;

                    if (response.ok && result.success) {
                        setTimeout(() => window.location.reload(), 800);
                    }
                });
            }

            document.querySelectorAll('.download-anexo').forEach(button => {
                button.addEventListener('click', async function () {
                    const downloadUrl = this.dataset.downloadUrl;
                    const fileName = this.dataset.fileName || 'anexo';

                    try {
                        await downloadFile(downloadUrl, fileName);
                    } catch (error) {
                        alert(error.message || 'Não foi possível baixar o anexo.');
                    }
                });
            });

            document.querySelectorAll('.delete-anexo').forEach(button => {
                button.addEventListener('click', async function () {
                    const anexoId = this.dataset.anexoId;
                    const deleteUrl = this.dataset.deleteUrl;
                    const token = getAntiForgeryToken();
                    const formData = new FormData();
                    formData.append('id', anexoId);
                    formData.append('__RequestVerificationToken', token);

                    const { response, result } = await postFormData(deleteUrl, formData);

                    if (response.ok && result.success) {
                        window.location.reload();
                    } else {
                        alert(result.message || 'Não foi possível remover o anexo.');
                    }
                });
            });
        });
    </script>
}
