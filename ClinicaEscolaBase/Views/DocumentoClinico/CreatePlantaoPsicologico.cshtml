@model ClinicaEscolaBase.ViewModels.PlantaoPsicologicoViewModel
@{
    ViewData["Title"] = "Plantão Psicológico";
}

<div class="container-fluid">
    <h2>@ViewData["Title"] - @Model.PacienteNome</h2>

    <form method="post" asp-action="CreatePlantaoPsicologico">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PacienteId" />
        <input type="hidden" asp-for="ProntuarioId" />

        <div class="card mb-3">
            <div class="card-header fw-bold">Identificação</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DataAtendimento" class="form-label"></label>
                        <input asp-for="DataAtendimento" class="form-control" type="datetime-local" />
                        <span asp-validation-for="DataAtendimento" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="NomeEstagiario" class="form-label"></label>
                        <input asp-for="NomeEstagiario" class="form-control" />
                        <span asp-validation-for="NomeEstagiario" class="text-danger"></span>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NomeSupervisor" class="form-label"></label>
                        <input asp-for="NomeSupervisor" class="form-control" />
                        <span asp-validation-for="NomeSupervisor" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CRPSupervisor" class="form-label"></label>
                        <input asp-for="CRPSupervisor" class="form-control" />
                        <span asp-validation-for="CRPSupervisor" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header fw-bold">Relato Clínico</div>
            <div class="card-body">
                <div class="mb-3">
                    <label asp-for="SinteseQueixaInicial" class="form-label"></label>
                    <textarea asp-for="SinteseQueixaInicial" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="SinteseQueixaInicial" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="RelatoAtendimento" class="form-label"></label>
                    <textarea asp-for="RelatoAtendimento" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="RelatoAtendimento" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="CondutaEncaminhamento" class="form-label"></label>
                    <textarea asp-for="CondutaEncaminhamento" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="CondutaEncaminhamento" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Salvar Plantão</button>
            <a asp-controller="Paciente" asp-action="Details" asp-route-id="@Model.PacienteId" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
