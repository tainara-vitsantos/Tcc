@model ClinicaEscolaBase.Models.PacienteModel
@using ClinicaEscolaBase.Enums

@{
    ViewData["Title"] = "Detalhes do Paciente";
    Layout = "_LayoutAdmin";
    
    // Lógica simples para calcular idade na View
    var idade = Model.DataNascimento.HasValue 
        ? (DateTime.Now.Year - Model.DataNascimento.Value.Year) - (DateTime.Now.DayOfYear < Model.DataNascimento.Value.DayOfYear ? 1 : 0) 
        : 0;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold"><i class="bi bi-person-badge me-2"></i>Ficha do Paciente</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-pencil-square"></i> Editar
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Voltar
            </a>
        </div>
    </div>

    <div class="row">
        <!-- COLUNA DA ESQUERDA: DADOS PESSOAIS -->
        <div class="col-md-8">
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-person-lines-fill me-2"></i> Informações Pessoais
                </div>
                <div class="card-body">
                    <h3 class="text-primary fw-bold">@Model.NomeCompleto</h3>
                    <hr />
                    <div class="row">
                        <div class="col-sm-4 fw-bold">Data de Nascimento:</div>
                        <div class="col-sm-8">
                            @Model.DataNascimento?.ToString("dd/MM/yyyy") 
                            <span class="badge bg-light text-dark border ms-2">@idade anos</span>
                        </div>

                        <div class="col-sm-4 fw-bold">CPF:</div>
                        <div class="col-sm-8">@(Model.CPF ?? "Não informado")</div>

                        <div class="col-sm-4 fw-bold">RG:</div>
                        <div class="col-sm-8">@(Model.RG ?? "Não informado")</div>

                        <div class="col-sm-4 fw-bold">Escolaridade:</div>
                        <div class="col-sm-8">@(Model.Escolaridade ?? "Não informado")</div>
                    </div>
                </div>
            </div>

            <!-- BLOCO DE ENDEREÇO -->
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-geo-alt-fill me-2"></i> Endereço e Contato
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-sm-6 mb-3">
                            <label class="fw-bold d-block text-muted small">Logradouro</label>
                            <span>@Model.EnderecoLogradouro, @Model.EnderecoNumero</span>
                        </div>
                        <div class="col-sm-3 mb-3">
                            <label class="fw-bold d-block text-muted small">Bairro</label>
                            <span>@Model.Bairro</span>
                        </div>
                        <div class="col-sm-3 mb-3">
                            <label class="fw-bold d-block text-muted small">Cidade</label>
                            <span>@Model.Cidade</span>
                        </div>
                        <div class="col-sm-6">
                            <label class="fw-bold d-block text-muted small">Telefone Principal</label>
                            <span class="text-primary fw-bold">@Model.Telefone</span>
                        </div>
                        <div class="col-sm-6">
                            <label class="fw-bold d-block text-muted small">Telefone para Recado</label>
                            <span>@Model.TelefoneRecado</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- COLUNA DA DIREITA: STATUS E PRONTUÁRIO -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body text-center">
                    <h5 class="fw-bold">Status Clínico</h5>
                    @if (Model.Prontuario != null)
                    {
                        <div class="alert alert-success d-flex align-items-center justify-content-center">
                            <i class="bi bi-check-circle-fill me-2"></i> PRONTUÁRIO ATIVO
                        </div>
                        <p class="small text-muted">Nº @Model.Prontuario.NumeroProntuario</p>
                        <a asp-controller="Prontuario" asp-action="Details" asp-route-id="@Model.Prontuario.Id" class="btn btn-outline-success btn-sm w-100">
                            Ver Prontuário Completo
                        </a>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i> SEM PRONTUÁRIO
                        </div>
                        <a asp-controller="Prontuario" asp-action="Create" asp-route-pacienteId="@Model.Id" class="btn btn-success w-100">
                            <i class="bi bi-folder-plus"></i> Abrir Prontuário
                        </a>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-info text-white fw-bold">
                    <i class="bi bi-journal-medical me-2"></i> Documentos Clínicos
                </div>
                <div class="card-body">
                    @if (Model.Prontuario != null)
                    {
                        <div class="d-grid gap-2 mb-3">
                            <a asp-controller="DocumentoClinico" asp-action="CreateAnamneseAdulto" asp-route-pacienteId="@Model.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-pencil-square me-1"></i>Anamnese Adulto
                            </a>
                            <a asp-controller="DocumentoClinico" asp-action="CreateAnamneseAdolescente" asp-route-pacienteId="@Model.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil-square me-1"></i>Anamnese Adolescente
                            </a>
                        </div>
                    }

                    @if (Model.DocumentosClinicos != null && Model.DocumentosClinicos.Any())
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var documento in Model.DocumentosClinicos.OrderByDescending(d => d.DataDocumento).Take(4))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong>@documento.TipoDocumento</strong><br />
                                        <small class="text-muted">@documento.DataDocumento.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <a asp-controller="DocumentoClinico" asp-action="Details" asp-route-id="@documento.Id" class="btn btn-sm btn-outline-secondary">Ver</a>
                                </li>
                            }
                        </ul>
                        <div class="mt-3 text-end">
                            <a asp-controller="DocumentoClinico" asp-action="Index" class="btn btn-sm btn-link">Ver todos os documentos</a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted small">
                            Nenhum documento cadastrado para este paciente.
                        </div>
                    }
                </div>
            </div>

            <!-- HISTÓRICO RÁPIDO -->
            <div class="card shadow-sm border-0">
                <div class="card-header fw-bold">Últimos Atendimentos</div>
                <div class="list-group list-group-flush">
                    @if (Model.Atendimentos != null && Model.Atendimentos.Any())
                    {
                        @foreach (var atend in Model.Atendimentos.OrderByDescending(a => a.DataHoraInicio).Take(3))
                        {
                            <div class="list-group-item">
                                <small class="d-block fw-bold text-primary">@atend.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")</small>
                                <small class="text-muted">@atend.TipoAtendimento</small>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted small">Nenhum histórico recente.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>