@model IEnumerable<ClinicaEscolaBase.Models.PacienteModel>

@{
    ViewData["Title"] = "Pacientes";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pacientes</h1>
    <a asp-action="Create" class="btn btn-primary">Novo Paciente</a>
</div>

<table class="table table-striped table-bordered">
    <thead class="table-light">
        <tr>
            <th>Nome</th>
            <th>CPF</th>
            <th>Telefone</th>
            <th>Cidade</th>
            <th class="text-end">Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var paciente in Model)
        {
            <tr>
                <td>@paciente.NomeCompleto</td>
                <td>@paciente.CPF</td>
                <td>@paciente.Telefone</td>
                <td>@paciente.Cidade</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@paciente.Id" class="btn btn-sm btn-info me-1">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@paciente.Id" class="btn btn-sm btn-warning me-1">Editar</a>
                    <a asp-action="Delete" asp-route-id="@paciente.Id" class="btn btn-sm btn-danger">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>