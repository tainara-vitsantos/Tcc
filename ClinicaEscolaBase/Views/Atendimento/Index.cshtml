@model IEnumerable<ClinicaEscolaBase.Models.Atendimento>

@{
    ViewData["Title"] = "Gestão de Atendimentos";
    Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">Atendimentos</h1>
            <p class="text-muted mb-0">Gerencie a agenda e o histórico de consultas.</p>
        </div>
        <a asp-controller="Paciente" asp-action="Index" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus me-2"></i>Novo Agendamento
        </a>
    </div>

    <!-- BOX DE FILTROS -->
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label small fw-bold">Buscar Paciente</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0" 
                               placeholder="Digite o nome..." value="@ViewData["CurrentFilter"]" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Filtrar por Data</label>
                    <input type="date" name="searchDate" class="form-control" value="@ViewData["CurrentDate"]" />
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-dark w-100">Filtrar Atendimentos</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Limpar</a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning border-0 shadow-sm text-center py-4">
            <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
            Nenhum atendimento encontrado para os critérios selecionados.
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Paciente</th>
                        <th>Data / Hora</th>
                        <th>Tipo</th>
                        <th>Status</th>
                        <th class="text-end pe-3">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3">
                                <div class="fw-bold">@item.Paciente?.NomeCompleto</div>
                                <small class="text-muted">Prontuário: @item.Prontuario?.NumeroProntuario</small>
                            </td>
                            <td>
                                <div class="fw-bold">@item.DataHoraInicio.ToString("dd/MM/yyyy")</div>
                                <small class="text-muted">@item.DataHoraInicio.ToString("HH:mm")</small>
                            </td>
                            <td>@item.TipoAtendimento</td>
                            <td>
                                @{
                                    var badgeClass = item.StatusAtendimento switch {
                                        ClinicaEscolaBase.Enums.StatusAtendimento.Realizado => "bg-success",
                                        ClinicaEscolaBase.Enums.StatusAtendimento.Agendado => "bg-info text-dark",
                                        ClinicaEscolaBase.Enums.StatusAtendimento.Cancelado => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass">@item.StatusAtendimento</span>
                            </td>
                            <td class="text-end pe-3">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white border"><i class="bi bi-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white border"><i class="bi bi-pencil"></i></a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white border text-danger"><i class="bi bi-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-4">
        <a asp-controller="Paciente" asp-action="Index" class="btn btn-link text-decoration-none">
            <i class="bi bi-arrow-left"></i> Voltar para Lista de Pacientes
        </a>
    </div>
</div>