@model ClinicaEscolaBase.Models.Atendimento

@{
    ViewData["Title"] = "Editar Atendimento";
}

<div class="container mt-4">
    <h1 class="fw-bold text-primary mb-4"><i class="bi bi-pencil-square"></i> Editar Atendimento</h1>

    <div class="row">
        <!-- FORMULÁRIO DE EDIÇÃO -->
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white fw-bold">Editar Informações</div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        
                        @* Campos ocultos para manter a integridade dos vínculos *@
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PacienteId" />
                        <input type="hidden" asp-for="ProntuarioId" />
                        <input type="hidden" asp-for="AlunoId" />

                        <div class="row gy-3">
                            <div class="col-md-6">
                                <label asp-for="TipoAtendimento" class="form-label fw-bold">Tipo de Atendimento</label>
                                <select asp-for="TipoAtendimento" class="form-select" asp-items="@(ViewData["TipoAtendimento"] as SelectList)">
                                    <option value="">Selecione...</option>
                                </select>
                                <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="StatusAtendimento" class="form-label fw-bold">Status</label>
                                <select asp-for="StatusAtendimento" class="form-select" asp-items="@(ViewData["StatusAtendimento"] as SelectList)">
                                </select>
                                <span asp-validation-for="StatusAtendimento" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DataHoraInicio" class="form-label fw-bold">Data/Hora Início</label>
                                <input asp-for="DataHoraInicio" type="datetime-local" class="form-control" />
                                <span asp-validation-for="DataHoraInicio" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DataHoraFim" class="form-label fw-bold">Data/Hora Fim</label>
                                <input asp-for="DataHoraFim" type="datetime-local" class="form-control" />
                                <span asp-validation-for="DataHoraFim" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Observacoes" class="form-label fw-bold">Observações Adicionais</label>
                                <textarea asp-for="Observacoes" class="form-control" rows="4" placeholder="Escreva observações adicionais..."></textarea>
                                <span asp-validation-for="Observacoes" class="text-danger"></span>
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-success px-4">
                                    <i class="bi bi-save me-2"></i>Salvar Alterações
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Cancelar</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RESUMO LATERAL -->
        <div class="col-md-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px;">
                <div class="card-header bg-light fw-bold">Informações do Paciente</div>
                <div class="card-body">
                    <p class="mb-1 text-muted small">Paciente</p>
                    <p class="fw-bold">@Model.Paciente?.NomeCompleto</p>
                    
                    <p class="mb-1 text-muted small">Prontuário</p>
                    <p>@Model.Prontuario?.NumeroProntuario</p>
                    
                    <hr />
                    
                    <div class="alert alert-info py-2">
                        <i class="bi bi-info-circle me-2"></i>
                        <small>Para marcar como <strong>'Realizado'</strong>, é necessário ter pelo menos uma evolução registrada no sistema.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}