@model ClinicaEscolaBase.Models.Atendimento

@{
    ViewData["Title"] = "Agendar Atendimento";
}

<div class="container mt-4">
    <h1>Agendar Atendimento</h1>

    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Create" method="post">
                @* Sumário de Erros para ajudar no debug *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row gy-3">
                    <div class="col-12">
                        <div class="alert alert-info">
                            <strong>Paciente:</strong> @ViewBag.PacienteNome<br />
                            <strong>Prontuário:</strong> @ViewBag.ProntuarioNumero
                        </div>
                    </div>

                    @* Campos Ocultos Essenciais *@
                    <input type="hidden" asp-for="PacienteId" />
                    <input type="hidden" asp-for="ProntuarioId" />
                    <input type="hidden" asp-for="AlunoId" />

                    <div class="col-md-6">
                        <label asp-for="TipoAtendimento" class="form-label">Tipo de Atendimento</label>
                        <select asp-for="TipoAtendimento" class="form-select" asp-items="@(ViewData["TipoAtendimento"] as SelectList)">
                            <option value="">Selecione...</option>
                        </select>
                        <span asp-validation-for="TipoAtendimento" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StatusAtendimento" class="form-label">Status</label>
                        <select asp-for="StatusAtendimento" class="form-select" asp-items="@(ViewData["StatusAtendimento"] as SelectList)">
                        </select>
                        <span asp-validation-for="StatusAtendimento" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DataHoraInicio" class="form-label">Data/Hora Início</label>
                        <input asp-for="DataHoraInicio" type="datetime-local" class="form-control" />
                        <span asp-validation-for="DataHoraInicio" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DataHoraFim" class="form-label">Data/Hora Fim (Opcional)</label>
                        <input asp-for="DataHoraFim" type="datetime-local" class="form-control" />
                        <span asp-validation-for="DataHoraFim" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Observacoes" class="form-label">Observações</label>
                        <textarea asp-for="Observacoes" class="form-control" rows="3" placeholder="Detalhes do agendamento..."></textarea>
                        <span asp-validation-for="Observacoes" class="text-danger"></span>
                    </div>

                    <div class="col-12 mt-4">
                        <button type="submit" class="btn btn-primary">Confirmar Agendamento</button>
                        <a asp-controller="Paciente" asp-action="Details" asp-route-id="@Model.PacienteId" class="btn btn-outline-secondary ms-2">Voltar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}