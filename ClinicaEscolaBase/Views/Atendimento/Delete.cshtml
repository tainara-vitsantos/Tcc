@model ClinicaEscolaBase.Models.Atendimento

@{
    ViewData["Title"] = "Excluir Atendimento";
        Layout = "_LayoutAdmin";
}

<div class="container mt-4">
    <div class="alert alert-danger shadow-sm border-0 d-flex align-items-center" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
        <div>
            <h4 class="alert-heading fw-bold mb-1">Atenção!</h4>
            <p class="mb-0">Você tem certeza que deseja excluir este atendimento? Esta ação não pode ser desfeita e removerá todas as evoluções vinculadas.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-bold">Resumo do Registro</div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Paciente</dt>
                <dd class="col-sm-8 fw-bold">@Model.Paciente?.NomeCompleto</dd>

                <dt class="col-sm-4 text-muted">Prontuário</dt>
                <dd class="col-sm-8">@Model.Prontuario?.NumeroProntuario</dd>

                <dt class="col-sm-4 text-muted">Data / Hora Início</dt>
                <dd class="col-sm-8 text-danger">@Model.DataHoraInicio.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-4 text-muted">Tipo de Atendimento</dt>
                <dd class="col-sm-8">@Model.TipoAtendimento</dd>

                <dt class="col-sm-4 text-muted">Status Atual</dt>
                <dd class="col-sm-8">
                    <span class="badge bg-secondary">@Model.StatusAtendimento</span>
                </dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post">
        @* Recomendado usar o input hidden padrão do ASP.NET Core *@
        <input type="hidden" asp-for="Id" />
        
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash-fill me-2"></i>Confirmar Exclusão
            </button>
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                <i class="bi bi-x-circle me-1"></i>Cancelar e Voltar
            </a>
        </div>
    </form>
</div>