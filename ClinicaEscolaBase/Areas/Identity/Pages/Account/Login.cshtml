@page
@model LoginModel

@{
ViewData["Title"] = "Log in - ConnectaMente";
Layout = "/Views/Shared/_Layout.cshtml";
}

@section Styles { <link rel="stylesheet" href="~/css/home.css" /> <link rel="stylesheet" href="~/css/login.css" />
}

<div class="split-container">

<!-- COLUNA ESQUERDA -->
<div class="brand-side">

    <div class="brand-glow"></div>

    <div class="hero-top">

        <div class="logo-area">
            <div class="logo-icon">
                <i class="bi bi-intersect"></i>
            </div>

            <span class="logo-text">
                ConnectaMente
            </span>
        </div>

        <div class="hero-content">

            <span class="feature-tag">
                <i class="bi bi-shield-check"></i>
                Conformidade LGPD & Sigilo Clínico
            </span>

            <h1 class="hero-title">
                Gestão inteligente para clínicas-escola de psicologia.
            </h1>

            <p class="hero-description">
                Plataforma premium desenvolvida para coordenadores,
                supervisores e alunos, unificando atendimento clínico,
                supervisão acadêmica e gestão institucional.
            </p>

        </div>

        <div class="dashboard-preview">

            <div class="dashboard-card large-card">

                <div class="dashboard-card-header">
                    <span>Pacientes Ativos</span>
                    <i class="bi bi-heart-pulse"></i>
                </div>

                <h2>128</h2>
                <small>+12% este mês</small>

            </div>

            <div class="dashboard-grid">

                <div class="dashboard-card">

                    <div class="dashboard-card-header">
                        <span>Supervisões</span>
                        <i class="bi bi-clipboard-check"></i>
                    </div>

                    <h3>24</h3>

                </div>

                <div class="dashboard-card">

                    <div class="dashboard-card-header">
                        <span>Alunos</span>
                        <i class="bi bi-mortarboard"></i>
                    </div>

                    <h3>36</h3>

                </div>

            </div>

        </div>

    </div>

    <div class="hero-bottom">

        <div class="feature-item">

            <div class="feature-icon">
                <i class="bi bi-person-workspace"></i>
            </div>

            <div>
                <h6>Supervisão Inteligente</h6>
                <p>Acompanhamento acadêmico e clínico em tempo real.</p>
            </div>

        </div>

        <div class="feature-item">

            <div class="feature-icon">
                <i class="bi bi-folder2-open"></i>
            </div>

            <div>
                <h6>Prontuário Seguro</h6>
                <p>Centralização criptografada dos registros clínicos.</p>
            </div>

        </div>

    </div>

</div>

<!-- COLUNA DIREITA -->

<div class="form-side">

    <div class="card-auth">

        <div class="mobile-logo d-lg-none">

            <div class="logo-icon">
                <i class="bi bi-intersect"></i>
            </div>

            <span class="logo-text dark">
                ConnectaMente
            </span>

        </div>

        <div class="auth-header">

            <span class="welcome-badge">
                Plataforma Institucional
            </span>

            <h2>
                Acessar plataforma
            </h2>

            <p>
                Entre com suas credenciais para acessar
                o painel clínico e acadêmico.
            </p>

        </div>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="validation-card"
                 role="alert">
            </div>

            <!-- EMAIL -->

            <div class="input-group-premium mb-3">

                <div class="input-icon">
                    <i class="bi bi-envelope"></i>
                </div>

                <div class="form-floating">

                    <input asp-for="Input.Email"
                           class="form-control premium-input"
                           autocomplete="username"
                           aria-required="true"
                           placeholder="name@example.com" />

                    <label asp-for="Input.Email">
                        E-mail Institucional
                    </label>

                </div>

            </div>

            <span asp-validation-for="Input.Email"
                  class="field-validation-error">
            </span>

            <!-- SENHA -->

            <div class="input-group-premium mt-3 mb-3">

                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                </div>

                <div class="form-floating">

                    <input asp-for="Input.Password"
                           id="passwordInput"
                           class="form-control premium-input"
                           autocomplete="current-password"
                           aria-required="true"
                           placeholder="password" />

                    <label asp-for="Input.Password">
                        Senha
                    </label>

                </div>

                <button type="button"
                        class="password-toggle"
                        onclick="togglePassword()">

                    <i id="passwordIcon"
                       class="bi bi-eye">
                    </i>

                </button>

            </div>

            <span asp-validation-for="Input.Password"
                  class="field-validation-error">
            </span>

            <!-- LEMBRAR -->

            <div class="d-flex justify-content-between align-items-center my-4">

                <div class="form-check">

                    <input class="form-check-input"
                           asp-for="Input.RememberMe" />

                    <label asp-for="Input.RememberMe"
                           class="form-check-label text-secondary small">

                        Lembrar de mim

                    </label>

                </div>

                <div class="login-links">

                    <a asp-page="./ForgotPassword">
                        Esqueceu a senha?
                    </a>

                </div>

            </div>

            <button id="login-submit"
                    type="submit"
                    class="btn-premium btn-login border-0 w-100">

                Entrar no Sistema

                <i class="bi bi-arrow-right"></i>

            </button>

            <div class="text-center mt-4 login-links">

                <span class="text-muted small">
                    Novo por aqui?
                </span>

                <a asp-page="./Register"
                   asp-route-returnUrl="@Model.ReturnUrl">

                    Solicitar acesso

                </a>

            </div>

        </form>

        <div class="footer-auth">

            <span>
                © @DateTime.Now.Year ConnectaMente
            </span>

            <div class="footer-links">

                <a asp-page="./ResendEmailConfirmation">
                    Confirmar E-mail
                </a>

            </div>

        </div>

    </div>

</div>


</div>

@section Scripts {


<partial name="_ValidationScriptsPartial" />

<script>

    function togglePassword() {

        const password =
            document.getElementById("passwordInput");

        const icon =
            document.getElementById("passwordIcon");

        if (password.type === "password") {

            password.type = "text";

            icon.classList.remove("bi-eye");
            icon.classList.add("bi-eye-slash");

        } else {

            password.type = "password";

            icon.classList.remove("bi-eye-slash");
            icon.classList.add("bi-eye");

        }
    }

</script>


}
